{
  "name": "igor-mcp-lab",
  "version": "1.0.0",
  "description": "MCP server lab deployment on Azure",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit false",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "node --test --import tsx/esm src/__tests__/*.test.ts",
    "test:built": "node --test dist/__tests__/*.test.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

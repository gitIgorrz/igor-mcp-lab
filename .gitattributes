# Normalize all text files to LF in the repo; Git converts to CRLF on
# Windows checkout automatically. This prevents "LF will be replaced by CRLF"
# warnings and ensures consistent diffs across platforms.
* text=auto eol=lf

# Explicitly mark binary files so Git never touches their line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.exe  binary
